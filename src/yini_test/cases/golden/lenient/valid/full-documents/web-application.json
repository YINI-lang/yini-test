{
  "WebApplication": {
    "name": "aurora-portal",
    "version": "2.4.0",
    "environment": "staging",
    "enabled": true,
    "Server": {
      "host": "0.0.0.0",
      "port": 8080,
      "publicUrl": "https://portal.example.com"
    },
    "Security": {
      "csrfProtection": true,
      "allowedHosts": [
        "portal.example.com",
        "localhost"
      ]
    },
    "Database": {
      "engine": "postgres",
      "host": "db.internal",
      "port": 5432,
      "pool": {
        "min": 2,
        "max": 20
      }
    },
    "Features": {
      "enabled": [
        "search",
        "audit-log",
        "bulk-export"
      ],
      "maintenanceMode": false
    }
  }
}
